{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndexedWordTimingResultV2",
  "description": "Forced-alignment indexed response.",
  "type": "object",
  "required": [
    "indexed_timings"
  ],
  "properties": {
    "indexed_timings": {
      "description": "Indexed timing results aligned to the request words.",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "$ref": "#/definitions/IndexedWordTimingV2"
          },
          {
            "type": "null"
          }
        ]
      }
    }
  },
  "definitions": {
    "IndexedWordTimingV2": {
      "description": "One word-level timing result.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "end_ms",
        "start_ms"
      ],
      "properties": {
        "confidence": {
          "description": "Optional model confidence.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "end_ms": {
          "description": "End time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "start_ms": {
          "description": "Start time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}