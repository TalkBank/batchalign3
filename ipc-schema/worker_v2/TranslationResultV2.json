{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TranslationResultV2",
  "description": "Batched translation response payload.",
  "type": "object",
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "description": "Item results aligned to the prepared batch payload order.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/TranslationItemResultV2"
      }
    }
  },
  "definitions": {
    "TranslationItemResultV2": {
      "description": "One translation item result returned by Python.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        },
        "raw_translation": {
          "description": "Raw model translation when inference succeeded.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}