{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpeakerResultV2",
  "description": "Raw speaker diarization output returned by the model host.",
  "type": "object",
  "required": [
    "segments"
  ],
  "properties": {
    "segments": {
      "description": "Ordered diarization segments.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/SpeakerSegmentV2"
      }
    }
  },
  "definitions": {
    "SpeakerSegmentV2": {
      "description": "One raw speaker diarization segment returned by Python.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "end_ms",
        "speaker",
        "start_ms"
      ],
      "properties": {
        "end_ms": {
          "description": "Segment end in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "speaker": {
          "description": "Stable speaker label chosen by the model adapter.",
          "type": "string"
        },
        "start_ms": {
          "description": "Segment start in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}