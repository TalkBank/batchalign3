{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AvqiResultV2",
  "description": "Raw AVQI output returned by the model host.",
  "type": "object",
  "required": [
    "avqi",
    "cpps",
    "cs_file",
    "hnr",
    "shimmer_local",
    "shimmer_local_db",
    "slope",
    "success",
    "sv_file",
    "tilt"
  ],
  "properties": {
    "avqi": {
      "description": "AVQI score.",
      "type": "number",
      "format": "double"
    },
    "cpps": {
      "description": "Cepstral Peak Prominence Smoothed.",
      "type": "number",
      "format": "double"
    },
    "cs_file": {
      "description": "Continuous-speech file label echoed by the worker.",
      "type": "string"
    },
    "error": {
      "description": "Optional runtime error detail.",
      "type": [
        "string",
        "null"
      ]
    },
    "hnr": {
      "description": "Harmonics-to-noise ratio.",
      "type": "number",
      "format": "double"
    },
    "shimmer_local": {
      "description": "Local shimmer percentage.",
      "type": "number",
      "format": "double"
    },
    "shimmer_local_db": {
      "description": "Local shimmer in dB.",
      "type": "number",
      "format": "double"
    },
    "slope": {
      "description": "LTAS slope.",
      "type": "number",
      "format": "double"
    },
    "success": {
      "description": "Whether the runtime succeeded.",
      "type": "boolean"
    },
    "sv_file": {
      "description": "Sustained-vowel file label echoed by the worker.",
      "type": "string"
    },
    "tilt": {
      "description": "LTAS tilt.",
      "type": "number",
      "format": "double"
    }
  }
}