{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AsrRequestV2",
  "description": "V2 ASR request payload.",
  "type": "object",
  "required": [
    "backend",
    "input",
    "lang"
  ],
  "properties": {
    "backend": {
      "description": "Backend selected by Rust.",
      "allOf": [
        {
          "$ref": "#/definitions/AsrBackendV2"
        }
      ]
    },
    "input": {
      "description": "Backend-specific input transport.",
      "allOf": [
        {
          "$ref": "#/definitions/AsrInputV2"
        }
      ]
    },
    "lang": {
      "description": "Input language for the transcript.",
      "type": "string"
    }
  },
  "definitions": {
    "AsrBackendV2": {
      "description": "ASR backend selected by the Rust control plane.",
      "oneOf": [
        {
          "description": "Local Whisper runtime hosted in Python.",
          "type": "string",
          "enum": [
            "local_whisper"
          ]
        },
        {
          "description": "Tencent Cantonese ASR provider.",
          "type": "string",
          "enum": [
            "hk_tencent"
          ]
        },
        {
          "description": "Aliyun Cantonese ASR provider.",
          "type": "string",
          "enum": [
            "hk_aliyun"
          ]
        },
        {
          "description": "FunASR Cantonese provider.",
          "type": "string",
          "enum": [
            "hk_funaudio"
          ]
        },
        {
          "description": "Rev.AI provider.",
          "type": "string",
          "enum": [
            "revai"
          ]
        }
      ]
    },
    "AsrInputV2": {
      "description": "ASR input variants for V2.",
      "oneOf": [
        {
          "description": "Local prepared audio path.",
          "type": "object",
          "required": [
            "audio_ref_id",
            "kind"
          ],
          "properties": {
            "audio_ref_id": {
              "description": "Artifact id of the audio descriptor included in `attachments`.",
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "prepared_audio"
              ]
            }
          }
        },
        {
          "description": "Provider-local media path.",
          "type": "object",
          "required": [
            "kind",
            "media_path",
            "num_speakers"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "provider_media"
              ]
            },
            "media_path": {
              "description": "Media file path readable by the worker host.",
              "type": "string"
            },
            "num_speakers": {
              "description": "Expected number of speakers for diarization-aware providers.",
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        },
        {
          "description": "Previously submitted provider job.",
          "type": "object",
          "required": [
            "kind",
            "provider_job_id"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "submitted_job"
              ]
            },
            "provider_job_id": {
              "description": "Provider job identifier to poll.",
              "type": "string"
            }
          }
        }
      ]
    }
  }
}