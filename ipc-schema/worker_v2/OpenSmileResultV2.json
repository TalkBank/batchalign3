{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenSmileResultV2",
  "description": "Raw openSMILE output returned by the model host.",
  "type": "object",
  "properties": {
    "audio_file": {
      "description": "Source audio identifier echoed by the worker.",
      "type": "string"
    },
    "duration_segments": {
      "description": "Number of result rows/segments.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "error": {
      "description": "Optional runtime error detail.",
      "type": [
        "string",
        "null"
      ]
    },
    "feature_level": {
      "description": "Requested feature-level name.",
      "type": "string"
    },
    "feature_set": {
      "description": "Requested feature-set name.",
      "type": "string"
    },
    "num_features": {
      "description": "Number of extracted feature columns.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "rows": {
      "description": "Tabular feature rows keyed by feature name.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "success": {
      "description": "Whether the underlying runtime succeeded.",
      "type": "boolean"
    }
  },
  "required": [
    "feature_set",
    "feature_level",
    "num_features",
    "duration_segments",
    "audio_file",
    "rows",
    "success"
  ]
}