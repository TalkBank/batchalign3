{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UtsegResultV2",
  "description": "Batched utterance-segmentation response payload.",
  "type": "object",
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "description": "Item results aligned to the prepared batch payload order.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/UtsegItemResultV2"
      }
    }
  },
  "definitions": {
    "UtsegItemResultV2": {
      "description": "One utseg item result returned by Python.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        },
        "trees": {
          "description": "Raw constituency trees when inference succeeded.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}