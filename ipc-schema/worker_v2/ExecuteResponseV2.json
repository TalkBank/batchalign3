{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecuteResponseV2",
  "description": "Top-level V2 execute response.",
  "type": "object",
  "required": [
    "elapsed_s",
    "outcome",
    "request_id"
  ],
  "properties": {
    "elapsed_s": {
      "description": "Execution time in seconds.",
      "type": "number",
      "format": "double"
    },
    "outcome": {
      "description": "Success or typed protocol/runtime error.",
      "allOf": [
        {
          "$ref": "#/definitions/ExecuteOutcomeV2"
        }
      ]
    },
    "request_id": {
      "description": "Correlation id for the request.",
      "type": "string"
    },
    "result": {
      "description": "Typed task result when execution succeeded.",
      "default": null,
      "anyOf": [
        {
          "$ref": "#/definitions/TaskResultV2"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "AsrElementKindV2": {
      "description": "Stable vocabulary for one monologue element returned by an ASR provider.",
      "oneOf": [
        {
          "description": "Lexical content that should become transcript tokens.",
          "type": "string",
          "enum": [
            "text"
          ]
        },
        {
          "description": "Punctuation emitted by the provider.",
          "type": "string",
          "enum": [
            "punctuation"
          ]
        }
      ]
    },
    "AsrElementV2": {
      "description": "One raw ASR element inside a speaker monologue.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "confidence": {
          "description": "Optional model/provider confidence score.",
          "default": null,
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "end_s": {
          "description": "End timestamp in seconds when the provider exposes one.",
          "default": null,
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "kind": {
          "description": "Stable element kind selected by the worker adapter.",
          "allOf": [
            {
              "$ref": "#/definitions/AsrElementKindV2"
            }
          ]
        },
        "start_s": {
          "description": "Start timestamp in seconds when the provider exposes one.",
          "default": null,
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "value": {
          "description": "Surface token or punctuation value.",
          "type": "string"
        }
      }
    },
    "AsrMonologueV2": {
      "description": "One speaker-attributed monologue returned by a provider ASR backend.",
      "type": "object",
      "required": [
        "elements",
        "speaker"
      ],
      "properties": {
        "elements": {
          "description": "Ordered elements inside the monologue.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/AsrElementV2"
          }
        },
        "speaker": {
          "description": "Stable speaker label chosen by the worker adapter.",
          "type": "string"
        }
      }
    },
    "CorefAnnotationV2": {
      "description": "One per-sentence coreference annotation returned by Python.",
      "type": "object",
      "required": [
        "sentence_idx",
        "words"
      ],
      "properties": {
        "sentence_idx": {
          "description": "Sentence index inside the corresponding document item.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "words": {
          "description": "Per-word chain references parallel to the sentence words.",
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/CorefChainRefV2"
            }
          }
        }
      }
    },
    "CorefChainRefV2": {
      "description": "One structured coreference chain reference returned by Python.",
      "type": "object",
      "required": [
        "chain_id",
        "is_end",
        "is_start"
      ],
      "properties": {
        "chain_id": {
          "description": "Chain identifier assigned by the coreference runtime.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "is_end": {
          "description": "Whether the current word ends this mention.",
          "type": "boolean"
        },
        "is_start": {
          "description": "Whether the current word starts this mention.",
          "type": "boolean"
        }
      }
    },
    "CorefItemResultV2": {
      "description": "One coreference item result returned by Python.",
      "type": "object",
      "properties": {
        "annotations": {
          "description": "Structured sparse annotations when inference succeeded.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/CorefAnnotationV2"
          }
        },
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ExecuteOutcomeV2": {
      "description": "Top-level execute outcome.",
      "oneOf": [
        {
          "description": "Request completed successfully.",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "success"
              ]
            }
          }
        },
        {
          "description": "Request failed at the protocol/runtime boundary.",
          "type": "object",
          "required": [
            "code",
            "kind",
            "message"
          ],
          "properties": {
            "code": {
              "description": "Stable protocol error category.",
              "allOf": [
                {
                  "$ref": "#/definitions/ProtocolErrorCodeV2"
                }
              ]
            },
            "kind": {
              "type": "string",
              "enum": [
                "error"
              ]
            },
            "message": {
              "description": "Human-readable detail for logs and tests.",
              "type": "string"
            }
          }
        }
      ]
    },
    "IndexedWordTimingV2": {
      "description": "One word-level timing result.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "end_ms",
        "start_ms"
      ],
      "properties": {
        "confidence": {
          "description": "Optional model confidence.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "end_ms": {
          "description": "End time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "start_ms": {
          "description": "Start time in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "MorphosyntaxItemResultV2": {
      "description": "One morphosyntax item result returned by Python.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        },
        "raw_sentences": {
          "description": "Raw Stanza `doc.to_dict()` sentence arrays when inference succeeded.",
          "type": [
            "array",
            "null"
          ],
          "items": true
        }
      }
    },
    "ProtocolErrorCodeV2": {
      "description": "Error category for protocol-level failures.",
      "oneOf": [
        {
          "description": "Worker/runtime does not understand the requested protocol version.",
          "type": "string",
          "enum": [
            "unsupported_protocol"
          ]
        },
        {
          "description": "Request payload shape was invalid for the task.",
          "type": "string",
          "enum": [
            "invalid_payload"
          ]
        },
        {
          "description": "Required attachment was not supplied.",
          "type": "string",
          "enum": [
            "missing_attachment"
          ]
        },
        {
          "description": "Attachment existed logically but could not be read.",
          "type": "string",
          "enum": [
            "attachment_unreadable"
          ]
        },
        {
          "description": "Model or SDK runtime for the task is unavailable.",
          "type": "string",
          "enum": [
            "model_unavailable"
          ]
        },
        {
          "description": "Runtime failed while executing the task.",
          "type": "string",
          "enum": [
            "runtime_failure"
          ]
        }
      ]
    },
    "SpeakerSegmentV2": {
      "description": "One raw speaker diarization segment returned by Python.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "end_ms",
        "speaker",
        "start_ms"
      ],
      "properties": {
        "end_ms": {
          "description": "Segment end in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "speaker": {
          "description": "Stable speaker label chosen by the model adapter.",
          "type": "string"
        },
        "start_ms": {
          "description": "Segment start in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "TaskResultV2": {
      "description": "Typed execute result payload.",
      "oneOf": [
        {
          "description": "Whisper chunk output.",
          "type": "object",
          "required": [
            "chunks",
            "kind",
            "lang",
            "text"
          ],
          "properties": {
            "chunks": {
              "description": "Raw chunk spans.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/WhisperChunkSpanV2"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "whisper_chunk_result"
              ]
            },
            "lang": {
              "description": "Transcript language.",
              "type": "string"
            },
            "text": {
              "description": "Concatenated transcript text.",
              "type": "string"
            }
          }
        },
        {
          "description": "Provider-shaped speaker monologue output.",
          "type": "object",
          "required": [
            "kind",
            "lang",
            "monologues"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "monologue_asr_result"
              ]
            },
            "lang": {
              "description": "Transcript language reported by the provider adapter.",
              "type": "string"
            },
            "monologues": {
              "description": "Speaker-grouped ASR output.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/AsrMonologueV2"
              }
            }
          }
        },
        {
          "description": "Raw Whisper FA token timings.",
          "type": "object",
          "required": [
            "kind",
            "tokens"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "whisper_token_timing_result"
              ]
            },
            "tokens": {
              "description": "Raw token timings in model order.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/WhisperTokenTimingV2"
              }
            }
          }
        },
        {
          "description": "Forced-alignment indexed timings.",
          "type": "object",
          "required": [
            "indexed_timings",
            "kind"
          ],
          "properties": {
            "indexed_timings": {
              "description": "Indexed timing results aligned to the request words.",
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/IndexedWordTimingV2"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "indexed_word_timing_result"
              ]
            }
          }
        },
        {
          "description": "Batched morphosyntax result.",
          "type": "object",
          "required": [
            "items",
            "kind"
          ],
          "properties": {
            "items": {
              "description": "Item results aligned to the prepared batch payload order.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/MorphosyntaxItemResultV2"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "morphosyntax_result"
              ]
            }
          }
        },
        {
          "description": "Batched utterance-segmentation result.",
          "type": "object",
          "required": [
            "items",
            "kind"
          ],
          "properties": {
            "items": {
              "description": "Item results aligned to the prepared batch payload order.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/UtsegItemResultV2"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "utseg_result"
              ]
            }
          }
        },
        {
          "description": "Batched translation result.",
          "type": "object",
          "required": [
            "items",
            "kind"
          ],
          "properties": {
            "items": {
              "description": "Item results aligned to the prepared batch payload order.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/TranslationItemResultV2"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "translation_result"
              ]
            }
          }
        },
        {
          "description": "Batched coreference result.",
          "type": "object",
          "required": [
            "items",
            "kind"
          ],
          "properties": {
            "items": {
              "description": "Item results aligned to the prepared batch payload order.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/CorefItemResultV2"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "coref_result"
              ]
            }
          }
        },
        {
          "description": "Raw speaker diarization result.",
          "type": "object",
          "required": [
            "kind",
            "segments"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "speaker_result"
              ]
            },
            "segments": {
              "description": "Ordered diarization segments.",
              "type": "array",
              "items": {
                "$ref": "#/definitions/SpeakerSegmentV2"
              }
            }
          }
        },
        {
          "description": "Raw openSMILE result.",
          "type": "object",
          "required": [
            "audio_file",
            "duration_segments",
            "feature_level",
            "feature_set",
            "kind",
            "num_features",
            "rows",
            "success"
          ],
          "properties": {
            "audio_file": {
              "description": "Source audio identifier echoed by the worker.",
              "type": "string"
            },
            "duration_segments": {
              "description": "Number of result rows/segments.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "error": {
              "description": "Optional runtime error detail.",
              "type": [
                "string",
                "null"
              ]
            },
            "feature_level": {
              "description": "Requested feature-level name.",
              "type": "string"
            },
            "feature_set": {
              "description": "Requested feature-set name.",
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "opensmile_result"
              ]
            },
            "num_features": {
              "description": "Number of extracted feature columns.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "rows": {
              "description": "Tabular feature rows keyed by feature name.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": {
                  "type": "number",
                  "format": "double"
                }
              }
            },
            "success": {
              "description": "Whether the underlying runtime succeeded.",
              "type": "boolean"
            }
          }
        },
        {
          "description": "Raw AVQI result.",
          "type": "object",
          "required": [
            "avqi",
            "cpps",
            "cs_file",
            "hnr",
            "kind",
            "shimmer_local",
            "shimmer_local_db",
            "slope",
            "success",
            "sv_file",
            "tilt"
          ],
          "properties": {
            "avqi": {
              "description": "AVQI score.",
              "type": "number",
              "format": "double"
            },
            "cpps": {
              "description": "Cepstral Peak Prominence Smoothed.",
              "type": "number",
              "format": "double"
            },
            "cs_file": {
              "description": "Continuous-speech file label echoed by the worker.",
              "type": "string"
            },
            "error": {
              "description": "Optional runtime error detail.",
              "type": [
                "string",
                "null"
              ]
            },
            "hnr": {
              "description": "Harmonics-to-noise ratio.",
              "type": "number",
              "format": "double"
            },
            "kind": {
              "type": "string",
              "enum": [
                "avqi_result"
              ]
            },
            "shimmer_local": {
              "description": "Local shimmer percentage.",
              "type": "number",
              "format": "double"
            },
            "shimmer_local_db": {
              "description": "Local shimmer in dB.",
              "type": "number",
              "format": "double"
            },
            "slope": {
              "description": "LTAS slope.",
              "type": "number",
              "format": "double"
            },
            "success": {
              "description": "Whether the runtime succeeded.",
              "type": "boolean"
            },
            "sv_file": {
              "description": "Sustained-vowel file label echoed by the worker.",
              "type": "string"
            },
            "tilt": {
              "description": "LTAS tilt.",
              "type": "number",
              "format": "double"
            }
          }
        }
      ]
    },
    "TranslationItemResultV2": {
      "description": "One translation item result returned by Python.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        },
        "raw_translation": {
          "description": "Raw model translation when inference succeeded.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "UtsegItemResultV2": {
      "description": "One utseg item result returned by Python.",
      "type": "object",
      "properties": {
        "error": {
          "description": "Optional per-item runtime error.",
          "type": [
            "string",
            "null"
          ]
        },
        "trees": {
          "description": "Raw constituency trees when inference succeeded.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "WhisperChunkSpanV2": {
      "description": "One raw Whisper chunk span returned by Python.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "end_s",
        "start_s",
        "text"
      ],
      "properties": {
        "end_s": {
          "description": "End timestamp in seconds.",
          "type": "number",
          "format": "double"
        },
        "start_s": {
          "description": "Start timestamp in seconds.",
          "type": "number",
          "format": "double"
        },
        "text": {
          "description": "Surface text for the chunk.",
          "type": "string"
        }
      }
    },
    "WhisperTokenTimingV2": {
      "description": "One raw Whisper forced-alignment token span returned by Python.\n\nTiming fields validated upstream by Python Pydantic models (see module docs).",
      "type": "object",
      "required": [
        "text",
        "time_s"
      ],
      "properties": {
        "text": {
          "description": "Surface token text returned by the FA runtime.",
          "type": "string"
        },
        "time_s": {
          "description": "Token onset timestamp in seconds.",
          "type": "number",
          "format": "double"
        }
      }
    }
  }
}