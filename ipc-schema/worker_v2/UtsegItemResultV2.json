{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UtsegItemResultV2",
  "description": "One utseg item result returned by Python.",
  "type": "object",
  "properties": {
    "error": {
      "description": "Optional per-item runtime error.",
      "type": [
        "string",
        "null"
      ]
    },
    "trees": {
      "description": "Raw constituency trees when inference succeeded.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}