{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UtsegBatchItem",
  "description": "Input payload for a single utterance segmentation request.\n\nMatches the Python `UtsegBatchItem` Pydantic model.",
  "type": "object",
  "required": [
    "text",
    "words"
  ],
  "properties": {
    "text": {
      "description": "Full utterance text (for constituency parsing).",
      "type": "string"
    },
    "words": {
      "description": "Tokenized words from the utterance.",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}