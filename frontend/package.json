{
  "name": "batchalign-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:schema": "cd .. && cargo run -q -p batchalign-cli -- openapi --output frontend/openapi.json",
    "generate:types": "npm run generate:schema && npx openapi-typescript openapi.json -o src/generated/api.ts",
    "check:api": "bash ../scripts/check_dashboard_api_drift.sh",
    "build": "tsc && vite build",
    "build:deploy": "bash ../scripts/build_react_dashboard.sh",
    "e2e:install": "npm --prefix e2e ci",
    "e2e:browsers": "npm --prefix e2e run install:browsers",
    "test:e2e": "npm --prefix e2e run test --",
    "test:e2e:headed": "npm --prefix e2e run test:headed --",
    "test:e2e:setup": "npm run e2e:install && npm run e2e:browsers",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wouter": "^3.9.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7"
  }
}
